# ── Base de données ───────────────────────────────────────────────────────────
# MySQL (actif par défaut)
DATABASE_URL="mysql://user:password@192.168.1.100:3306/erp_perso"

# PostgreSQL (remplacez le provider dans schema.prisma par "postgresql")
# DATABASE_URL="postgresql://user:password@192.168.1.100:5432/erp_perso"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change_me_access_secret_at_least_32_chars"
JWT_REFRESH_SECRET="change_me_refresh_secret_at_least_32_chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"
